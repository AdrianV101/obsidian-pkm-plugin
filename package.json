{
  "name": "obsidian-pkm",
  "version": "2.0.0",
  "description": "Claude Code plugin for Obsidian vault integration — 19 MCP tools, hooks, and skills for PKM",
  "main": "cli.js",
  "exports": {
    ".": "./cli.js"
  },
  "bin": {
    "obsidian-pkm": "cli.js"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "*.js",
    "!eslint.config.js",
    "CHANGELOG.md",
    "hooks/",
    "templates/",
    "sample-project/",
    ".claude-plugin/",
    "commands/",
    "skills/",
    ".mcp.json"
  ],
  "scripts": {
    "start": "node cli.js",
    "test": "node --test tests/*.test.js",
    "lint": "eslint *.js tests/",
    "prepublishOnly": "npm test && npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdrianV101/obsidian-pkm-plugin.git"
  },
  "author": "Adrian Verhoosel",
  "license": "MIT",
  "keywords": [
    "mcp",
    "obsidian",
    "pkm",
    "knowledge-management",
    "claude-code",
    "model-context-protocol",
    "claude",
    "ai",
    "markdown",
    "notes",
    "semantic-search",
    "wikilinks",
    "plugin",
    "hooks"
  ],
  "homepage": "https://github.com/AdrianV101/obsidian-pkm-plugin#readme",
  "bugs": {
    "url": "https://github.com/AdrianV101/obsidian-pkm-plugin/issues"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "better-sqlite3": "^12.6.2",
    "js-yaml": "^4.1.0",
    "sqlite-vec": "^0.1.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.0"
  }
}
